# Ultra RAG Server Configuration
# Copy this to .env and fill in your values

# API key for remote access (leave empty for LAN-only/open mode)
ULTRA_RAG_API_KEY=your-secret-key-here

# MemoryWeb integration (set to "false" to disable)
MEMORYWEB_ENABLED=true
MEMORYWEB_URL=http://localhost:8100

# Client configuration (on remote systems)
ULTRA_RAG_URL=https://your-tunnel.trycloudflare.com
ULTRA_RAG_SYSTEM_ID=laptop-1
