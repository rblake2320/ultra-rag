# Ultra RAG Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# ── Database ──────────────────────────────────────────────────────────────────
RAG_DB_PASSWORD=yourpasswordhere

# ── NVIDIA NIM Reranker (optional) ───────────────────────────────────────────
# Sign up free at https://build.nvidia.com to get an API key.
# Leave blank to skip NIM reranking (system falls back to score-based sorting).
NVIDIA_API_KEY=nvapi-xxxx

# ── Claude / Anthropic API (optional fallback LLM) ───────────────────────────
# Used as a high-quality fallback if the local Ollama model is unavailable.
# Leave blank to use Ollama only.
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── OpenAI API (optional) ─────────────────────────────────────────────────────
# Optional: used in RAGAS evaluation if configured.
OPENAI_API_KEY=sk-xxxx
